# ═══════════════════════════════════════════════════════════════
# Alashore Marine Exports — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Rust / Cargo ──────────────────────────────────────────────
target/
**/*.rs.bk
*.pdb

# ── Dioxus ────────────────────────────────────────────────────
frontend/dist/
frontend/.dioxus/

# ── Node / pnpm ───────────────────────────────────────────────
node_modules/
.pnpm-store/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.npm/

# ── Playwright / Testing Artifacts ────────────────────────────
playwright-report/
test-results/
blob-report/
playwright/.cache/
e2e/results/
coverage/
*.lcov
.nyc_output/

# ── Environment & Credentials ─────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials.json
service-account*.json
**/secrets/
**/*.secret

# ── Database ──────────────────────────────────────────────────
data/*.db
data/*.db-shm
data/*.db-wal
*.sqlite
*.sqlite3
*.sqlite-journal

# ── OS Generated ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.fleet/
.nova/
*.code-workspace

# ── Claude Code ───────────────────────────────────────────────
.claude/

# ── Python (if any scripting) ─────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.tox/

# ── Docker ────────────────────────────────────────────────────
*.log
docker-compose.override.yml

# ── Offline / Local Assets ────────────────────────────────────
offline/

# ── Build / Misc ──────────────────────────────────────────────
dist/
build/
out/
tmp/
*.tmp
*.bak
*.orig
*.patch
