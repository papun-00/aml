# ─────────────────────────────────────────────────────────────
# Alashore Marine Exports — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── API Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8046

# ── Database ───────────────────────────────────────────────────
# SQLite (default, no setup required)
DATABASE_URL=sqlite://data/alashore.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/alashore

# ── Email / SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@alashoremarine.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=export@alashoremarine.com

# ── Frontend ───────────────────────────────────────────────────
# Public base URL (used for canonical URLs and OG tags)
PUBLIC_BASE_URL=https://alashoremarine.com

# API URL (where frontend sends requests)
PUBLIC_API_URL=https://alashoremarine.com/api/v1

# ── Logging ────────────────────────────────────────────────────
RUST_LOG=info,backend=debug,shared=debug

# ── Security ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_secure_random_string_64_chars_minimum

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8045,http://127.0.0.1:8045
